# Copy this to .env and fill in your Wyze credentials.
# .env is gitignored — never commit real credentials.

WYZE_EMAIL=your@email.com
WYZE_PASSWORD=yourpassword

# If your account uses 2FA, generate API credentials at https://developer.wyze.com
# and use these instead of email/password:
# WYZE_API_KEY=
# WYZE_API_ID=
